{
  "manifest_version": 3,
  "name": "AI Assistant Connector",
  "version": "0.1.0",
  "description": "Floating AI assistant with visual links to page elements",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.pinterest.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_page": "options.html"
}
